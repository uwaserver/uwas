# UWAS + WordPress Configuration
# Copy this file and edit with your values

# ─── Domain ──────────────────────────────────────────────────────
DOMAIN=example.com
ADMIN_EMAIL=admin@example.com

# ─── Database ────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_root_password_here
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=change_me_db_password_here

# ─── UWAS Admin ─────────────────────────────────────────────────
UWAS_ADMIN_KEY=change_me_admin_api_key_here
ADMIN_PORT=9443

# ─── PHP ─────────────────────────────────────────────────────────
PHP_MEMORY_LIMIT=256M

# ─── Optional: Cloudflare (for DNS-01 challenge) ────────────────
# CF_API_TOKEN=your_cloudflare_api_token
