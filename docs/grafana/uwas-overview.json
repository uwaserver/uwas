          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(uwas_cache_hits_total[5m])) / (sum(rate(uwas_cache_hits_total[5m])) + sum(rate(uwas_cache_misses_total[5m]))) * 100",
