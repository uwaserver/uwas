        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "expr": "rate(uwas_requests_total[5m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
