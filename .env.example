# UWAS — Docker Compose environment variables
# Copy to .env and set real values. Never commit a .env with secrets.

# Admin API key for the dashboard + container healthcheck.
# UWAS refuses to start a publicly-bound admin listener without auth, so this
# is required. Generate one with: openssl rand -hex 24
UWAS_ADMIN_KEY=please-change-this-admin-key

# Database (MariaDB) credentials
DB_ROOT_PASSWORD=uwas_root
DB_PASSWORD=uwas_wp

# Backup restore database connection (optional).
# These are read by the `mysql` CLI during backup restore to connect via TCP
# instead of the default Unix socket. The compose file wires these to the `db`
# service automatically — only override if using an external database.
# UWAS_DB_HOST=db
# UWAS_DB_PORT=3306
# UWAS_DB_USER=root
# UWAS_DB_PASSWORD=${DB_ROOT_PASSWORD}
