# UWAS — Docker Compose environment variables
# Copy to .env and set real values. Never commit a .env with secrets.

# Admin API key for the dashboard + container healthcheck.
# UWAS refuses to start a publicly-bound admin listener with no key or a
# well-known placeholder, so a strong unique value is REQUIRED. Replace the
# value below before running. Generate one with: openssl rand -hex 24
UWAS_ADMIN_KEY=replace-me-openssl-rand-hex-24

# Database (MariaDB) credentials — REQUIRED (compose fails fast if unset).
# Replace with strong unique values; generate with: openssl rand -hex 24
DB_ROOT_PASSWORD=replace-me-db-root-password
DB_PASSWORD=replace-me-db-app-password

# Backup restore database connection (optional).
# These are read by the `mysql` CLI during backup restore to connect via TCP
# instead of the default Unix socket. The compose file wires these to the `db`
# service automatically — only override if using an external database.
# UWAS_DB_HOST=db
# UWAS_DB_PORT=3306
# UWAS_DB_USER=root
# UWAS_DB_PASSWORD=${DB_ROOT_PASSWORD}
